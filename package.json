{
  "name": "trymon-binary-engine",
  "version": "1.0.0",
  "description": "TRYMON-BINARY-ENGINE: Run native Linux binaries (.AppImage, .deb, .rpm) on the Web.",
  "main": "script.js",
  "scripts": {
    "dev": "vite",
    "server": "npm --prefix server run dev",
    "dev:full": "concurrently \"npm run dev\" \"npm run server\"",
    "build": "tsc && vite build",
    "build:wasm": "wasm-pack build src/kernel-rust --target web --out-dir ../wasm/pkg",
    "build:all": "npm run build:wasm && npm run build",
    "preview": "vite preview"
  },
  "keywords": [
    "binary",
    "linux",
    "emulator",
    "web",
    "webvm",
    "v86",
    "runtime"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "lucide-react": "^1.7.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "v86": "^0.5.319"
  }
}
